# === gestorIA Backend - Environment Variables ===

# Entorno: "development" (default) | "production"
ENVIRONMENT=development

# --- Base de datos ---
# Dev (SQLite, default):
# DATABASE_URL=sqlite+aiosqlite:///./gestoria.db
# Prod (Supabase PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- API Keys ---
CAPSOLVER_API_KEY=
MULTABOT_API_KEY=

# --- Chrome (solo overridear si no es la ruta default) ---
# Windows: C:/Program Files/Google/Chrome/Application/chrome.exe
# Linux:   /usr/bin/chromium-browser
# CHROME_PATH=/usr/bin/chromium-browser

# --- CORS (origins separados por coma) ---
# Dev:
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Prod:
# CORS_ORIGINS=https://tu-dominio.com

# --- Server ---
# Dev:  127.0.0.1 (solo local)
# Prod: 127.0.0.1 (Nginx hace reverse proxy)
# HOST=127.0.0.1
# PORT=8001
